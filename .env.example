# Web Push (obrigatório para notificações com app fechado)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@example.com

# Protege o endpoint de cron (Vercel envia automaticamente; use o mesmo valor em cron externo)
CRON_SECRET=

# Plano Vercel Hobby: cron nativo 2x/dia (7h e 19h UTC). Para lembretes precisos,
# use um serviço gratuito (ex.: cron-job.org) chamando GET /api/push/cron a cada 5 min
# com header: Authorization: Bearer SEU_CRON_SECRET

# Opcional: Upstash Redis para produção (sem isso, usa arquivo local em dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
